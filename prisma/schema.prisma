generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("SUPPLIER") // BUYER or SUPPLIER
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company? @relation(fields: [companyId], references: [id])
  companyId String?

  requirements Requirement[]
  inquiries    Inquiry[]
}

enum Plan {
  FREE
  STARTER
  PRO
  PREMIUM
}

model Company {
  id          String   @id @default(cuid())
  name        String
  description String?
  location    String?
  logoUrl     String?
  catalogueUrl String?
  tags        String   // comma-separated
  products_legacy String? // Keeping old field for compatibility
  isPremium   Boolean  @default(false)
  isVerified  Boolean  @default(false)
  plan        Plan     @default(FREE)
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  
  users       User[]
  items       Product[] // NEW: Real products
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  imageUrl    String?
  category    String?
  price       String?

  company     Company  @relation(fields: [companyId], references: [id])
  companyId   String

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Requirement {
  id           String   @id @default(cuid())
  title        String
  description  String
  quantity     String
  budget       String?
  deadline     String?
  tags         String   // comma-separated
  status       String   @default("Active") // Active, Urgent, Closed
  buyerDetails String
  contactName  String?
  contactEmail String?
  contactPhone String?

  author       User     @relation(fields: [authorId], references: [id])
  authorId     String

  responses    Int      @default(0)
  inquiries    Inquiry[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Inquiry {
  id            String   @id @default(cuid())
  message       String
  companyName   String
  contactName   String
  contactEmail  String
  contactPhone  String?
  country       String
  
  requirement   Requirement @relation(fields: [requirementId], references: [id])
  requirementId String
  
  sender        User?    @relation(fields: [senderId], references: [id])
  senderId      String?

  createdAt     DateTime @default(now())
}
